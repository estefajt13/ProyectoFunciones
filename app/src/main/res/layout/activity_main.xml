<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F0EB">

    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Bienvenido"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#2C2C2C"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="80dp"/>

    <Button
        android:id="@+id/btnAdmin"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Administrador"
        android:textSize="16sp"
        android:backgroundTint="#4A6FA5"
        android:onClick="irAdmin"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo"
        app:layout_constraintBottom_toTopOf="@id/btnUsuario"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnUsuario"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Usuario"
        android:textSize="16sp"
        android:backgroundTint="#6B8E7F"
        android:onClick="irLogin"
        app:layout_constraintTop_toBottomOf="@id/btnAdmin"
        app:layout_constraintBottom_toTopOf="@id/layoutCreditos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"/>

    <!-- Bloque informacion estudiante -->
    <LinearLayout
        android:id="@+id/layoutCreditos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Desarrollado por:"
            android:textSize="12sp"
            android:textColor="#888888" />

        <TextView
            android:id="@+id/tvNombreEstudiante"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estefania Jaramillo Torres"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#555555" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>