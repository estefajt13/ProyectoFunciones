<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvTitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Nuevo Contacto"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etNombre"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:hint="Nombre"
            android:inputType="textPersonName"
            android:background="@android:color/white"
            android:paddingStart="12dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitulo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etApellido"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:hint="Apellido"
            android:inputType="textPersonName"
            android:background="@android:color/white"
            android:paddingStart="12dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/etNombre"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etCedula"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:hint="Cédula"
            android:inputType="number"
            android:background="@android:color/white"
            android:paddingStart="12dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/etApellido"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnFecha"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="Seleccionar fecha de nacimiento"
            android:backgroundTint="#5A7A8A"
            android:onClick="abrirCalendario"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/etCedula"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvFecha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Fecha de nacimiento: no seleccionada"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/btnFecha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etCorreo"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:hint="Correo electrónico"
            android:inputType="textEmailAddress"
            android:background="@android:color/white"
            android:paddingStart="12dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvFecha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etDireccion"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:hint="Dirección"
            android:inputType="text"
            android:background="@android:color/white"
            android:paddingStart="12dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/etCorreo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/lblDepartamento"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Departamento"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/etDireccion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Spinner
            android:id="@+id/spinnerDepartamento"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:background="@android:color/white"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/lblDepartamento"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/lblCiudad"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Ciudad"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/spinnerDepartamento"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Spinner
            android:id="@+id/spinnerCiudad"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:background="@android:color/white"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/lblCiudad"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnGustos"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="Gustos"
            android:backgroundTint="#7B6FA0"
            android:onClick="irGustos"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toBottomOf="@id/spinnerCiudad"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnPreferencias"/>

        <!-- 🔥 AQUÍ YA CORREGIDO -->
        <Button
            android:id="@+id/btnPreferencias"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="Preferencias"
            android:backgroundTint="#7B6FA0"
            android:onClick="irPreferencias"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/spinnerCiudad"
            app:layout_constraintStart_toEndOf="@id/btnGustos"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvGustos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Gustos: ninguno seleccionado"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/btnGustos"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvPreferencias"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Preferencias: ninguna seleccionada"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvGustos"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnEditar"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:text="Editar"
            android:backgroundTint="#C17B5A"
            android:onClick="activarEdicion"
            android:visibility="gone"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvPreferencias"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnGuardar"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:text="Guardar Contacto"
            android:backgroundTint="#4A6FA5"
            android:onClick="guardarContacto"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/btnEditar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnVolver"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="← Volver"
            android:backgroundTint="#5A7A8A"
            android:onClick="volver"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/btnGuardar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>