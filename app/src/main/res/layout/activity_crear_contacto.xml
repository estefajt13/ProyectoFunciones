<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvTitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Nuevo Contacto"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Nombre -->
        <EditText android:id="@+id/etNombre"
            android:layout_width="0dp" android:layout_height="50dp"
            android:hint="Nombre" android:inputType="textPersonName"
            android:background="@android:color/white" android:paddingStart="12dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitulo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Apellido -->
        <EditText android:id="@+id/etApellido"
            android:layout_width="0dp" android:layout_height="50dp"
            android:hint="Apellido" android:inputType="textPersonName"
            android:background="@android:color/white" android:paddingStart="12dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/etNombre"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Cédula -->
        <EditText android:id="@+id/etCedula"
            android:layout_width="0dp" android:layout_height="50dp"
            android:hint="Cédula" android:inputType="number"
            android:background="@android:color/white" android:paddingStart="12dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/etApellido"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Fecha de nacimiento -->
        <EditText android:id="@+id/etFecha"
            android:layout_width="0dp" android:layout_height="50dp"
            android:hint="Fecha de nacimiento (dd/mm/aaaa)"
            android:inputType="text"
            android:background="@android:color/white" android:paddingStart="12dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/etCedula"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Correo -->
        <EditText android:id="@+id/etCorreo"
            android:layout_width="0dp" android:layout_height="50dp"
            android:hint="Correo electrónico" android:inputType="textEmailAddress"
            android:background="@android:color/white" android:paddingStart="12dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/etFecha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Dirección -->
        <EditText android:id="@+id/etDireccion"
            android:layout_width="0dp" android:layout_height="50dp"
            android:hint="Dirección" android:inputType="text"
            android:background="@android:color/white" android:paddingStart="12dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/etCorreo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Ciudad -->
        <EditText android:id="@+id/etCiudad"
            android:layout_width="0dp" android:layout_height="50dp"
            android:hint="Ciudad" android:inputType="text"
            android:background="@android:color/white" android:paddingStart="12dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/etDireccion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Departamento -->
        <EditText android:id="@+id/etDepartamento"
            android:layout_width="0dp" android:layout_height="50dp"
            android:hint="Departamento" android:inputType="text"
            android:background="@android:color/white" android:paddingStart="12dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/etCiudad"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Botones Gustos y Preferencias -->
        <Button android:id="@+id/btnGustos"
            android:layout_width="0dp" android:layout_height="50dp"
            android:text="Gustos"
            android:backgroundTint="#2196F3"
            android:onClick="irGustos"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toBottomOf="@id/etDepartamento"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnPreferencias"/>

        <Button android:id="@+id/btnPreferencias"
            android:layout_width="0dp" android:layout_height="50dp"
            android:text="Preferencias"
            android:backgroundTint="#2196F3"
            android:onClick="irPreferencias"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/etDepartamento"
            app:layout_constraintStart_toEndOf="@id/btnGustos"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Indicadores de selección -->
        <TextView android:id="@+id/tvGustos"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:text="Gustos: ninguno seleccionado"
            android:textSize="12sp" android:textColor="#888888"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/btnGustos"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView android:id="@+id/tvPreferencias"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:text="Preferencias: ninguna seleccionada"
            android:textSize="12sp" android:textColor="#888888"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvGustos"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Botón Guardar -->
        <Button android:id="@+id/btnGuardar"
            android:layout_width="0dp" android:layout_height="55dp"
            android:text="Guardar Contacto"
            android:backgroundTint="#673AB7"
            android:onClick="guardarContacto"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvPreferencias"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>