<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#F2F0EB">

    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Panel Administrador"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#2C2C2C"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/lblNombre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Nombre"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/etNombre"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:hint="Ingresa el nombre"
        android:inputType="textPersonName"
        android:background="@android:color/white"
        android:paddingStart="12dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/lblNombre"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/lblUsername"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Nombre de usuario"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/etNombre"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/etUsername"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:hint="Ingresa el nombre de usuario"
        android:inputType="textNoSuggestions"
        android:background="@android:color/white"
        android:paddingStart="12dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/lblUsername"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/lblPassword"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Contraseña"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/etUsername"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:hint="Ingresa la contraseña"
        android:inputType="text"
        android:background="@android:color/white"
        android:paddingStart="12dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/lblPassword"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnGuardar"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Guardar Usuario"
        android:backgroundTint="#4A6FA5"
        android:onClick="guardarUsuario"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/etPassword"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvListaUsuarios"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Usuarios registrados: ninguno"
        android:textSize="13sp"
        android:textColor="#555555"
        android:layout_marginTop="16dp"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toBottomOf="@id/btnGuardar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Botón volver -->
    <Button
        android:id="@+id/btnVolver"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:text="← Volver"
        android:backgroundTint="#5A7A8A"
        android:onClick="volver"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvListaUsuarios"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>